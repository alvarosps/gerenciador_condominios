{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DJANGO_SETTINGS_MODULE": "condominios_manager.settings"
  },
  "permissions": {
    "allow": [
      "Bash(python manage.py runserver:*)",
      "Bash(python manage.py makemigrations:*)",
      "Bash(python manage.py showmigrations:*)",
      "Bash(python manage.py createsuperuser:*)",
      "Bash(python manage.py shell:*)",
      "Bash(python manage.py collectstatic:*)",
      "Bash(python -m pytest:*)",
      "Bash(pre-commit run:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(npx pyright:*)",
      "Bash(python scripts/backup_db.py:*)",
      "Bash(python scripts/generate_metrics.py:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm run test:*)",
      "Bash(npm install:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git worktree:*)",
      "Bash(git tag:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(node:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean -f:*)",
      "Bash(python manage.py flush:*)",
      "Bash(python manage.py sqlflush:*)",
      "Bash(python manage.py sqlclear:*)",
      "Bash(python manage.py reset_db:*)",
      "Bash(python manage.py dbshell:*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(python manage.py migrate:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-edit-scope.sh"
            ]
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/conventional-commit.cjs"
            ]
          },
          {
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-db-push-guard.sh"
            ]
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "supabase@claude-plugins-official": true
  }
}
