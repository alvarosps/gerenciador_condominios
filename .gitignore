/frontend/node_modules
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.Python
venv/
.venv/
ENV/
env/

# Django
*.log
logs/
db.sqlite3
db.sqlite3-journal
/static/
/media/
# Generated contract PDFs + uploaded payment proofs (PII) — never commit.
# contracts/ is MEDIA_ROOT (runtime output dir); keep the dir, ignore the PII files.
/contracts/**/*.pdf
/contracts/payment_proofs/
/Notificacao_*.pdf
*.pot

# Database backups & dumps (PII) — never commit. Root-only patterns so we
# don't catch core/migrations SQL, scripts/data seeds, or package.json/.mcp.json.
/backups/
/backup_json/
*.dump
/*.sql
/backup_*.json
/*.json.gz
/local_backup.*

# Template backups
core/templates/backups/

# Documentation (allow docs/ but ignore generated docs)
docs/_build/

# IDE
.vscode/
.idea/
.claude/settings.local.json
.claude/agent-memory/
.claude/worktrees/
CLAUDE.local.md
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
nul

# Metrics and reports
/metrics/

# Temporary files
*.tmp
*.bak
*.cache

# Visual Companion (brainstorming mockups)
.superpowers/

# Invoice-parser test fixtures: generated PDFs (regenerated from sanitized .txt by conftest; non-deterministic reportlab output). The .txt source is versioned.
tests/unit/test_finances/fixtures/invoices/*.pdf
