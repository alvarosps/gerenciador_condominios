# Condomínios Manager - Frontend Environment Configuration
# Copy this file to .env.local and update with your actual values
# IMPORTANT: Never commit .env.local to version control!

# =============================================================================
# API BACKEND URL
# =============================================================================

# Django REST API base URL (browser-side). In production this is the RELATIVE "/api"
# path, which is proxied to the backend by app/api/[...route]/route.ts (BACKEND_API_URL).
# Development: http://localhost:8008/api
# Production:  /api   (same-origin proxy — keeps auth cookies on the frontend domain)
NEXT_PUBLIC_API_URL=http://localhost:8008/api

# Absolute backend origin (browser-side). Used for backend resources that live OUTSIDE
# the /api proxy namespace and therefore need an absolute URL:
#   - django-allauth Google login start  (/accounts/google/login/)
#   - generated contract PDFs            (/contracts/...)
# Development: http://localhost:8008
# Production:  https://your-api-domain.com   (e.g. https://gerenciador-condominios.onrender.com)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008

# Server-side absolute backend base URL used by the Next proxy/redirect routes
# (app/api/[...route]/route.ts and app/download/route.ts). Set on the host (Vercel).
# Development: http://localhost:8008/api
# BACKEND_API_URL=http://localhost:8008/api

# =============================================================================
# GOOGLE OAUTH 2.0 CONFIGURATION
# =============================================================================

# Google OAuth is handled entirely server-side by django-allauth on the backend.
# The frontend has no client-side client id — it only redirects to the backend
# login-start endpoint and receives a short-lived code at its callback route.
#
# Setup instructions:
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Configure OAuth consent screen (APIs & Services > OAuth consent screen)
# 4. Go to APIs & Services > Credentials
# 5. Create OAuth 2.0 Client ID (Application type: Web application)
# 6. Add authorized JavaScript origins:
#    - http://localhost:6000 (development)
#    - https://your-frontend-domain.com (production)
# 7. Add authorized redirect URIs:
#    - http://localhost:8008/accounts/google/login/callback/ (backend callback)
#    - http://localhost:6000/auth/callback (frontend callback)
# 8. Set the Client ID / Client Secret on the BACKEND (.env), not here.
#
# See GOOGLE_OAUTH_SETUP.md for detailed setup guide

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application name (used in page titles and meta tags)
NEXT_PUBLIC_APP_NAME=Condomínios Manager

# Default page size for paginated lists
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20

# Cache buster for the persisted offline query cache (IndexedDB).
# Change this on each deploy to invalidate the stored cache. Optional in dev
# (defaults to 'dev').
# NEXT_PUBLIC_BUILD_ID=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable email/password registration
NEXT_PUBLIC_ENABLE_REGISTRATION=true

# Enable dark mode toggle
NEXT_PUBLIC_ENABLE_DARK_MODE=false

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================

# Google Analytics tracking ID (optional)
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Show debug information in development (do not use in production)
NEXT_PUBLIC_DEBUG=false

# Enable React Query DevTools in development
NEXT_PUBLIC_ENABLE_REACT_QUERY_DEVTOOLS=true

# =============================================================================
# NOTES
# =============================================================================

# 1. Copy this file to .env.local in the frontend directory
# 2. Update all values marked with "your-" placeholders
# 3. NEXT_PUBLIC_ prefix is required for environment variables to be accessible in the browser
# 4. Never commit .env.local to version control
# 5. For production, use Vercel/Netlify environment variable settings
# 6. Restart the Next.js dev server after changing environment variables

# =============================================================================
# PRODUCTION DEPLOYMENT
# =============================================================================

# For production deployment on Vercel/Netlify:
# 1. Set NEXT_PUBLIC_API_URL to your production API domain
# 2. Configure Google OAuth credentials on the BACKEND (allauth), not here
# 3. Ensure all API URLs use HTTPS in production
# 4. Update Google Cloud Console with production redirect URIs
# 5. Set NEXT_PUBLIC_DEBUG=false in production
