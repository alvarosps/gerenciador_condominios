{
  "pythonVersion": "3.14",
  "pythonPlatform": "All",

  "include": [
    "core",
    "condominios_manager",
    "finances",
    "scripts",
    "tests"
  ],
  "exclude": [
    "**/migrations",
    "**/__pycache__",
    "**/node_modules",
    ".venv",
    "venv",
    "env",
    "frontend",
    "contracts",
    "htmlcov",
    "build",
    "dist"
  ],

  "typeCheckingMode": "strict",

  "reportMissingImports": true,
  "reportMissingTypeStubs": false,
  "reportMissingModuleSource": false,
  "reportImportCycles": true,
  "reportUnusedImport": "error",
  "reportUnusedClass": "error",
  // pytest collects fixtures (esp. @pytest.fixture(autouse=True)) by name, not by direct
  // reference, so pyright reports them as unused — a false positive it cannot model.
  "reportUnusedFunction": "none",
  "reportUnusedVariable": "error",
  "reportDuplicateImport": "error",
  "reportUntypedFunctionDecorator": false,
  "reportUntypedClassDecorator": false,
  "reportUntypedBaseClass": false,
  "reportGeneralTypeIssues": "error",
  "reportOptionalMemberAccess": "error",
  "reportOptionalCall": "error",
  "reportOptionalIterable": "error",
  "reportOptionalSubscript": "error",
  "reportOptionalOperand": "error",
  "reportUnnecessaryIsInstance": "warning",
  "reportUnnecessaryCast": "warning",
  "reportUnnecessaryComparison": "warning",
  "reportUnnecessaryContains": "warning",
  "reportUnnecessaryTypeIgnoreComment": "error",
  // Django/django-stubs <-> pyright: pyright has no Django plugin (unlike mypy), so the
  // following rules fire en masse on legitimate Django patterns that mypy+django-stubs
  // already validates (mypy is the strict type gate and passes clean). Disabled here to
  // avoid hundreds of false positives; genuine issues are still caught by mypy.
  // - reportPrivateUsage: Django pseudo-private ORM API (_meta, _default_manager, _base_manager)
  // - reportConstantRedefinition: settings modules legitimately reassign UPPERCASE names
  // - reportIncompatible*Override: model field / Meta / save()/delete() overrides
  "reportPrivateUsage": "none",
  "reportConstantRedefinition": "none",
  "reportIncompatibleMethodOverride": "none",
  "reportIncompatibleVariableOverride": "none",
  "reportOverlappingOverload": "error",
  "reportPossiblyUnbound": "error",
  // Service/infra classes inherit object/Protocol/Generic; super().__init__() is a no-op here.
  "reportMissingSuperCall": "none",
  "reportPropertyTypeMismatch": "error",
  "reportUninitializedInstanceVariable": "none",
  // Flagged defaults are immutable Decimals (safe); ruff's ISC already enforces real implicit concat.
  "reportCallInDefaultInitializer": "none",
  "reportImplicitStringConcatenation": "none",
  "reportUnknownParameterType": false,
  "reportUnknownArgumentType": false,
  "reportUnknownLambdaType": false,
  "reportUnknownVariableType": false,
  "reportUnknownMemberType": false,
  "reportMissingParameterType": false,
  "reportMissingTypeArgument": false,
  "reportInvalidTypeVarUse": "error",
  "reportDeprecated": "warning",
  "reportInconsistentConstructor": "error",
  "reportMatchNotExhaustive": "error",
  "reportShadowedImports": "error",
  "reportImplicitOverride": false,

  // Django/django-stubs <-> pyright (see note above): ORM dynamics pyright cannot resolve
  // without the mypy plugin — reverse relations, the implicit `id`, FK `_id` shadows, and
  // Manager/QuerySet variance. mypy+django-stubs validates these correctly.
  "reportAttributeAccessIssue": "none",
  "reportArgumentType": "none",
  "reportReturnType": "error",
  // Celery/DRF/model_bakery/python-decouple lack pyright-compatible stubs (no runtime plugin
  // like mypy uses), so these fire only on library-typed call sites and loosely-typed test/
  // script data here — all false positives. mypy (strict, plugin-aware) is the gate for these.
  "reportIndexIssue": "none",
  "reportOperatorIssue": "none",
  "reportCallIssue": "none",
  "reportAssignmentType": "error",
  "reportRedefinedVariable": "warning",
  "reportAbstractUsage": "error",

  "stubPath": "",
  "venvPath": ".",
  "venv": ".venv",

  "executionEnvironments": [
    {
      "root": "core",
      "extraPaths": ["."]
    },
    {
      "root": "condominios_manager",
      "extraPaths": ["."]
    },
    {
      "root": "scripts",
      "extraPaths": ["."]
    },
    {
      "root": "tests",
      "extraPaths": ["."]
    }
  ]
}
